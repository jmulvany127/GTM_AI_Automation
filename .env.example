# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Leave as-is when running with Docker Compose.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/gtm_db

# Application environment: development or production
APP_ENV=development

# ── AI ────────────────────────────────────────────────────────────────────────
# Anthropic API key — required. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── CRM ───────────────────────────────────────────────────────────────────────
# HubSpot private app access token — create one in HubSpot Settings → Integrations → Private Apps
# Leave blank to disable HubSpot sync (pipeline will still run without it)
HUBSPOT_ACCESS_TOKEN=your_hubspot_access_token_here

# ── Notifications ─────────────────────────────────────────────────────────────
# Slack incoming webhook URL — create one at https://api.slack.com/apps
# Leave blank to disable Slack alerts (pipeline will still run without it)
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# ── Email ─────────────────────────────────────────────────────────────────────
# Gmail address to send outreach from
GMAIL_SENDER_ADDRESS=your_gmail_address@gmail.com

# Google App Password — NOT your regular Gmail password.
# Enable 2FA on your Google account first, then generate at https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=your_google_app_password_here

# ── Sender identity ───────────────────────────────────────────────────────────
# Your full name — appears in outreach email signatures and HubSpot owner field
USER_FULL_NAME=Your Full Name

# Your email — appears in HubSpot owner field
USER_EMAIL=your_email@company.com

# ── Company and product context ───────────────────────────────────────────────
# These values are injected into every agent system prompt. Fill them in to
# personalise the AI's outreach and analysis for your own company and ICP.

# Your company name
COMPANY_NAME=Your Company Name

# Your company location (e.g. New York City, NY)
COMPANY_LOCATION=Your City, State

# 2-3 sentence description of your company — stage, focus, team size
COMPANY_DESCRIPTION=Your company description here.

# What your product does in 1-2 sentences
PRODUCT_DESCRIPTION=Your product description here.

# Your core value proposition — what outcomes do customers achieve?
VALUE_PROPOSITION=Your value proposition here.

# Ideal customer profile — who do you sell to, what roles, what company profile?
TARGET_CUSTOMER=Your ideal customer profile here.

# Key product integrations — referenced in call intelligence output
KEY_INTEGRATIONS=Integration 1, Integration 2, Integration 3

# Pain points your product solves — used in outreach personalisation
KEY_PAIN_POINTS_WE_SOLVE=Pain point 1, Pain point 2, Pain point 3

# ── Sender signature ──────────────────────────────────────────────────────────
# Your job title — appears in outreach email signatures
SENDER_TITLE=Your Job Title

# Your company name in the sender signature (usually matches COMPANY_NAME)
SENDER_COMPANY=Your Company Name
